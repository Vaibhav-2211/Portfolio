{
  "version": 2,
  "public": true,
  "buildCommand": "npm run build:prod",
  "routes": [
    {
      "src": "/assets/(.*)",
      "dest": "/assets/$1"
    },
    {
      "src": "^/(.*\\.(js|css|png|jpg|jpeg|gif|svg|webp|woff|woff2|ttf|eot|pdf|xml|txt|json))$",
      "dest": "/dist/portfolio/browser/$1"
    },
    {
      "src": "^/(.*)$",
      "dest": "/api/index.js"
    }
  ],
  "functions": {
    "api/index.js": {
      "includeFiles": "dist/portfolio/**"
    }
  }
}